@startuml agentic_vs_claude_code_flow
!theme plain
skinparam actorStyle awesome

' Global dark theme settings
skinparam backgroundColor #000000
skinparam defaultFontColor #FFFFFF

' Note specific settings
skinparam note {
    BackgroundColor #FFFFFF
    BorderColor #000000
    FontColor #000000
}

' Sequence styling
skinparam sequence {
    LifeLineBorderColor #FFFFFF
    LifeLineBackgroundColor #000000
    ParticipantBorderColor #FFFFFF
    ParticipantBackgroundColor #000000
    ParticipantFontColor #FFFFFF
    GroupBackgroundColor #000000
    GroupBodyBackgroundColor #000000
    GroupBorderColor #FFFFFF
    GroupFontColor #FFFFFF
    DividerBackgroundColor #000000
    DividerBorderColor #FFFFFF
    DividerFontColor #FFFFFF
    ArrowColor #FFFFFF
    BoxBorderColor #FFFFFF
    BoxBackgroundColor #111111
    BoxFontColor #FFFFFF
}

' Colors
!$USER_COLOR = "#FFB6C1"
!$AGENT_COLOR = "#87CEEB"
!$LLM_COLOR = "#DAA520"

title Claude Code Flow — "Create Instagram API package with 5 endpoints"

actor "USER\n(CLI)" as U $USER_COLOR
participant "SINGLE AGENT\n(Node.js)" as A $AGENT_COLOR
participant "LLM\n(Opus 4.6)" as L $LLM_COLOR

autonumber

== Planning ==

U -[$USER_COLOR]> A: "create Instagram API"
activate A $AGENT_COLOR

A -[$AGENT_COLOR]> L: system prompt (~4,000 tokens)\n+ ALL tools (~3,000 tokens)\n+ conversation history
activate L $LLM_COLOR
L --> A: plan response\n~6,000 tokens
deactivate L

A -[$AGENT_COLOR]> U: show plan

== Entity Generation (context grows) ==

A -[$AGENT_COLOR]> L: Write entity_1.rs
note right: context: ~10K
L --> A: output: ~3K

A -[$AGENT_COLOR]> L: Write entity_2.rs
note right: context: ~15K
L --> A: output: ~3K

A -[$AGENT_COLOR]> L: Write entity_3.rs
note right: context: ~20K
L --> A: output: ~3K

A -[$AGENT_COLOR]> L: Write entity_4.rs
note right: context: ~25K
L --> A: output: ~3K

A -[$AGENT_COLOR]> L: Write entity_5.rs
note right: context: ~30K
L --> A: output: ~3K

== API Handler Generation (context keeps growing) ==

A -[$AGENT_COLOR]> L: Write api_handler_1.rs
note right: context: ~35K
A -[$AGENT_COLOR]> L: Write api_handler_2.rs
note right: context: ~40K
A -[$AGENT_COLOR]> L: Write api_handler_3.rs
note right: context: ~45K
A -[$AGENT_COLOR]> L: Write api_handler_4.rs
note right: context: ~50K
A -[$AGENT_COLOR]> L: Write api_handler_5.rs
note right: context: ~55K

== Tests & Config ==

A -[$AGENT_COLOR]> L: Write test files
note right: context: ~60K
A -[$AGENT_COLOR]> L: Write Cargo.toml
note right: context: ~65K
A -[$AGENT_COLOR]> L: Write config files
note right: context: ~70K
A -[$AGENT_COLOR]> L: Write README
note right: context: ~75K

== Build & Deploy ==

A -[$AGENT_COLOR]> L: Bash: cargo build
note right: context: ~80K
A -[$AGENT_COLOR]> L: Bash: cargo test
note right: context: ~85K
A -[$AGENT_COLOR]> L: Bash: git add + commit + push
note right: context: ~90K

deactivate A

A -[$AGENT_COLOR]> U: "Done"

note over U
  **TOTAL: ~120,000 tokens**
  **COST: ~$1.20**
  **TIME: 10-20 minutes**
  ALL tools sent on EVERY call (~3,000 tokens)
  Context GROWS with every file written
  No code generation — every line LLM-written
  No WASM, FFI, GUI, bridge generated
end note

@enduml
